{
  "name": "@a2ui/markdown-it",
  "version": "0.8.1",
  "description": "A2UI Markdown-It renderer",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "type": "module",
  "scripts": {
    "build": "wireit",
    "build:tsc": "wireit"
  },
  "wireit": {
    "build": {
      "dependencies": [
        "build:tsc"
      ]
    },
    "build:tsc": {
      "command": "tsc -b --pretty",
      "env": {
        "FORCE_COLOR": "1"
      },
      "files": [
        "src/**/*.ts",
        "tsconfig.json"
      ],
      "output": [
        "dist/",
        "!dist/**/*.min.js{,.map}"
      ],
      "clean": "if-file-deleted"
    }
  },
  "repository": {
    "directory": "renderers/markdown-it",
    "type": "git",
    "url": "git+https://github.com/google/A2UI.git"
  },
  "files": [
    "dist/src"
  ],
  "keywords": [],
  "author": "Google",
  "license": "Apache-2.0",
  "devDependencies": {
    "typescript": "^5.8.3",
    "wireit": "^0.15.0-pre.2"
  },
  "dependencies": {
    "@a2ui/lit": "file:../lit"
  }
}
